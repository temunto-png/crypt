# bitbank API キー（出金権限は付与しないこと）
# pydantic SecretStr で管理されるため、コードに直書きしない
CRYPT_BITBANK_API_KEY=your_api_key_here
CRYPT_BITBANK_API_SECRET=your_api_secret_here

# 取引モード: paper（デフォルト）または live
# live にする場合は --confirm-live フラグも必要（二段階ゲート）
CRYPT_MODE=paper

# Kill Switch の手動解除（解除時のみ 1 に設定。通常は設定しない）
# KILL_SWITCH_OVERRIDE=1
